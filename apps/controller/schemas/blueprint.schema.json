{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "size", "materials", "blocks", "tags"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "depth"],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1,
          "maximum": 96
        },
        "height": {
          "type": "integer",
          "minimum": 1,
          "maximum": 128
        },
        "depth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 96
        }
      }
    },
    "materials": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["material", "count"],
        "properties": {
          "material": {
            "type": "string",
            "pattern": "^minecraft:[a-z0-9_./-]+(\\[[a-z0-9_]+=[a-z0-9_]+(,[a-z0-9_]+=[a-z0-9_]+)*\\])?$"
          },
          "count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 2000
          }
        }
      }
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["x", "y", "z", "material"],
        "properties": {
          "x": {
            "type": "integer",
            "minimum": -96,
            "maximum": 96
          },
          "y": {
            "type": "integer",
            "minimum": 0,
            "maximum": 128
          },
          "z": {
            "type": "integer",
            "minimum": -96,
            "maximum": 96
          },
          "material": {
            "type": "string",
            "pattern": "^minecraft:[a-z0-9_./-]+(\\[[a-z0-9_]+=[a-z0-9_]+(,[a-z0-9_]+=[a-z0-9_]+)*\\])?$"
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
