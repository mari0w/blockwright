{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["reply", "summary", "mode", "actions"],
  "properties": {
    "reply": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "mode": {
      "type": "string",
      "enum": ["patch", "replace"]
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "blueprint_id", "origin", "blocks", "clear_existing"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["place_blocks"]
          },
          "blueprint_id": {
            "type": ["string", "null"],
            "minLength": 1,
            "maxLength": 96
          },
          "origin": {
            "type": "object",
            "additionalProperties": false,
            "required": ["world", "x", "y", "z"],
            "properties": {
              "world": {
                "type": ["string", "null"]
              },
              "x": {
                "type": "integer",
                "minimum": -30000000,
                "maximum": 30000000
              },
              "y": {
                "type": "integer",
                "minimum": -64,
                "maximum": 320
              },
              "z": {
                "type": "integer",
                "minimum": -30000000,
                "maximum": 30000000
              }
            }
          },
          "blocks": {
            "type": "array",
            "minItems": 1,
            "maxItems": 700,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["x", "y", "z", "material"],
              "properties": {
                "x": {
                  "type": "integer",
                  "minimum": -96,
                  "maximum": 96
                },
                "y": {
                  "type": "integer",
                  "minimum": -64,
                  "maximum": 96
                },
                "z": {
                  "type": "integer",
                  "minimum": -96,
                  "maximum": 96
                },
                "material": {
                  "type": "string",
                  "pattern": "^minecraft:[a-z0-9_./-]+(\\[[a-z0-9_]+=[a-z0-9_]+(,[a-z0-9_]+=[a-z0-9_]+)*\\])?$"
                }
              }
            }
          },
          "clear_existing": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
