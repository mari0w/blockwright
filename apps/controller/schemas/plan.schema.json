{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "attachmentSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "url", "download_code", "picture_download_code", "path"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["url", "ding_talk_download_code", "local_path"]
        },
        "url": { "type": ["string", "null"] },
        "download_code": { "type": ["string", "null"] },
        "picture_download_code": { "type": ["string", "null"] },
        "path": { "type": ["string", "null"] }
      }
    },
    "attachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "source", "file_name", "mime_type"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["image", "file", "audio", "video", "unknown"]
        },
        "source": { "$ref": "#/$defs/attachmentSource" },
        "file_name": { "type": ["string", "null"] },
        "mime_type": { "type": ["string", "null"] }
      }
    },
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z", "material"],
      "properties": {
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "z": { "type": "integer" },
        "material": { "type": "string" }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "z": { "type": "integer" }
      }
    },
    "blueprintPrimitive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "from", "to", "material"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["box", "fill_box", "cuboid", "hollow_box", "shell"]
        },
        "from": { "$ref": "#/$defs/point" },
        "to": { "$ref": "#/$defs/point" },
        "material": { "type": "string" }
      }
    },
    "blueprintSpec": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["format", "kind", "source", "intent", "notes", "primitives"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["blockwright.blueprint_spec.v1"]
        },
        "kind": { "type": "string" },
        "source": { "type": "string" },
        "intent": { "type": "string" },
        "notes": { "type": "string" },
        "primitives": {
          "type": "array",
          "items": { "$ref": "#/$defs/blueprintPrimitive" }
        }
      }
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["world", "x", "y", "z"],
      "properties": {
        "world": { "type": ["string", "null"] },
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "z": { "type": "integer" }
      }
    },
    "nullableOrigin": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["world", "x", "y", "z"],
      "properties": {
        "world": { "type": ["string", "null"] },
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "z": { "type": "integer" }
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "depth"],
      "properties": {
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "depth": { "type": "integer" }
      }
    },
    "materialCount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["material", "count"],
      "properties": {
        "material": { "type": "string" },
        "count": { "type": "integer" }
      }
    },
    "blueprint": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description",
        "size",
        "spec",
        "materials",
        "blocks",
        "primitives",
        "tags"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "size": { "$ref": "#/$defs/size" },
        "spec": { "$ref": "#/$defs/blueprintSpec" },
        "materials": {
          "type": "array",
          "items": { "$ref": "#/$defs/materialCount" }
        },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/block" }
        },
        "primitives": {
          "type": "array",
          "items": { "$ref": "#/$defs/blueprintPrimitive" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "player",
        "item",
        "count",
        "blueprint_id",
        "origin",
        "blocks",
        "clear_existing",
        "command",
        "message",
        "text",
        "attachments"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "give_item",
            "place_blocks",
            "run_command",
            "chat",
            "scan_nearby_and_plan"
          ]
        },
        "player": { "type": ["string", "null"] },
        "item": { "type": ["string", "null"] },
        "count": { "type": ["integer", "null"] },
        "blueprint_id": { "type": ["string", "null"] },
        "origin": { "$ref": "#/$defs/nullableOrigin" },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/block" }
        },
        "clear_existing": { "type": ["boolean", "null"] },
        "command": { "type": ["string", "null"] },
        "message": { "type": ["string", "null"] },
        "text": { "type": ["string", "null"] },
        "attachments": {
          "type": "array",
          "items": { "$ref": "#/$defs/attachment" }
        }
      }
    },
    "sitePlan": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["origin", "clear_existing", "pre_clear_blocks", "pre_foundation_blocks", "rationale"],
      "properties": {
        "origin": { "$ref": "#/$defs/nullableOrigin" },
        "clear_existing": { "type": ["boolean", "null"] },
        "pre_clear_blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/block" }
        },
        "pre_foundation_blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/block" }
        },
        "rationale": { "type": ["string", "null"] }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["reply", "summary", "blueprint", "site_plan", "actions"],
  "properties": {
    "reply": { "type": "string" },
    "summary": { "type": "string" },
    "blueprint": { "$ref": "#/$defs/blueprint" },
    "site_plan": { "$ref": "#/$defs/sitePlan" },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/action" }
    }
  }
}
