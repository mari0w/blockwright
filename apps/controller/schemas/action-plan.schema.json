{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["reply", "summary", "actions"],
  "properties": {
    "reply": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "player", "item", "count", "command", "message"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["give_item", "run_command", "chat"]
          },
          "player": {
            "type": ["string", "null"]
          },
          "item": {
            "type": ["string", "null"],
            "pattern": "^minecraft:[a-z0-9_./-]+$"
          },
          "count": {
            "type": ["integer", "null"],
            "minimum": 1,
            "maximum": 6400
          },
          "command": {
            "type": ["string", "null"],
            "minLength": 1,
            "maxLength": 160
          },
          "message": {
            "type": ["string", "null"],
            "minLength": 1,
            "maxLength": 300
          }
        }
      }
    }
  }
}
